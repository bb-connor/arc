{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chio KernelMessage capability_list",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "capabilities"],
  "properties": {
    "type": {
      "const": "capability_list"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "issuer", "subject", "scope", "issued_at", "expires_at", "signature"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "issuer": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "subject": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "grants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["server_id", "tool_name", "operations"],
                  "properties": {
                    "server_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "tool_name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "enum": [
                          "invoke",
                          "read_result",
                          "read",
                          "subscribe",
                          "get",
                          "delegate"
                        ]
                      }
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "max_invocations": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "max_cost_per_invocation": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["units", "currency"],
                      "properties": {
                        "units": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "currency": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    },
                    "max_total_cost": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["units", "currency"],
                      "properties": {
                        "units": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "currency": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    },
                    "dpop_required": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "resource_grants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["uri_pattern", "operations"],
                  "properties": {
                    "uri_pattern": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "enum": [
                          "invoke",
                          "read_result",
                          "read",
                          "subscribe",
                          "get",
                          "delegate"
                        ]
                      }
                    }
                  }
                }
              },
              "prompt_grants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["prompt_name", "operations"],
                  "properties": {
                    "prompt_name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "enum": [
                          "invoke",
                          "read_result",
                          "read",
                          "subscribe",
                          "get",
                          "delegate"
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "issued_at": {
            "type": "integer",
            "minimum": 0
          },
          "expires_at": {
            "type": "integer",
            "minimum": 0
          },
          "delegation_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["capability_id", "delegator", "delegatee", "timestamp", "signature"],
              "properties": {
                "capability_id": {
                  "type": "string",
                  "minLength": 1
                },
                "delegator": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "delegatee": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "attenuations": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "timestamp": {
                  "type": "integer",
                  "minimum": 0
                },
                "signature": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{128}$"
                }
              }
            }
          },
          "signature": {
            "type": "string",
            "pattern": "^[0-9a-f]{128}$"
          }
        }
      }
    }
  }
}
