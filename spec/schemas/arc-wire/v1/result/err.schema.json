{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chio ToolCallResult err",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "error"],
  "properties": {
    "status": {
      "const": "err"
    },
    "error": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {
              "const": "capability_denied"
            },
            "detail": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code"],
          "properties": {
            "code": {
              "const": "capability_expired"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code"],
          "properties": {
            "code": {
              "const": "capability_revoked"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {
              "const": "policy_denied"
            },
            "detail": {
              "type": "object",
              "additionalProperties": false,
              "required": ["guard", "reason"],
              "properties": {
                "guard": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {
              "const": "tool_server_error"
            },
            "detail": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {
              "const": "internal_error"
            },
            "detail": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
