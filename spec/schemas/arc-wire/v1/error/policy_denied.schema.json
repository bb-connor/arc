  "additionalProperties": false,
  "required": ["code", "detail"],
  "properties": {
    "code": {
      "const": "policy_denied"
    },
    "detail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guard", "reason"],
      "properties": {
        "guard": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
