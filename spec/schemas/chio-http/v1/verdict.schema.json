{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chio HTTP Verdict",
  "description": "Tagged union representing the evaluation verdict for an HTTP request.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict"],
      "properties": {
        "verdict": {
          "const": "allow"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "reason", "guard"],
      "properties": {
        "verdict": {
          "const": "deny"
        },
        "reason": {
          "type": "string"
        },
        "guard": {
          "type": "string"
        },
        "http_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "default": 403
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "reason"],
      "properties": {
        "verdict": {
          "const": "cancel"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "reason"],
      "properties": {
        "verdict": {
          "const": "incomplete"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  ]
}
