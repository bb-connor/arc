    {
      "sequence": 16,
      "timestamp": "2026-04-15T03:35:22Z",
      "event_type": "note.added",
      "actor": {
        "type": "user",
        "name": "Priya Narayanan",
        "id": "PUSR-6H8J"
      },
      "action": "Added root cause analysis note",
      "details": {
        "note": "The rule uses sanctioned-list-v7 with include_cloud_provider_ips=true and classification_mode=strict. Dry-run showed 0 false positives but I suspect the issue is that cloud provider IPs in non-sanctioned regions are being classified against their physical region mapping. The rule config resolves cloud IPs to physical data center locations, but many legitimate customers run inference from cloud VMs in eu-west, ap-southeast, etc."
      }
    },
    {
      "sequence": 17,
      "timestamp": "2026-04-15T03:38:47Z",
      "event_type": "note.added",
      "actor": {
        "type": "user",
        "name": "Elena Vasquez",
        "id": "PUSR-9E7B"
      },
      "action": "Added contributing factor note",
      "details": {
        "note": "Confirmed: the dry-run validation missed this because the sanctioned-list-v7 feed was updated on April 13 to include broader cloud provider IP ranges. The dry-run observation period started April 11 with the old feed. The feed update happened mid-observation but the dry-run stats were not reset."
      }
    },
    {
      "sequence": 18,
      "timestamp": "2026-04-15T03:39:30Z",
      "event_type": "note.added",
      "actor": {
        "type": "user",
        "name": "James Okonkwo",
        "id": "PUSR-3D5F"
      },
      "action": "Added remediation proposal",
      "details": {
        "note": "Proposed remediation: revert geo-restrict-v42 mode from blocking to dry-run. This requires a config change on the Stratos Networks side since we manage edge rules through their platform. We cannot self-serve this change."
      }
    },
    {
      "sequence": 19,
