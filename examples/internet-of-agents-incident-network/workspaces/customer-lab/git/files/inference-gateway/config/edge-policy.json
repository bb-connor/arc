{
  "schema_version": "2.4.0",
  "service": "inference-gateway",
  "last_modified": "2026-04-15T03:11:47Z",
  "last_modified_by": "priya.narayanan@meridian-labs.ai",
  "edge_provider": "stratos-networks",
  "evaluation_order": "priority_desc",
  "rules": [
    {
      "name": "rate-limit-global-v8",
      "description": "Global rate limiting for inference endpoints",
      "enabled": true,
      "mode": "enforcing",
      "priority": 100,
      "created_at": "2026-01-22T14:30:00Z",
      "last_modified": "2026-03-10T09:15:00Z",
      "owner": "platform-engineering",
      "conditions": {
        "path_match": ["/v1/inference/*", "/v1/embeddings/*"],
        "method": ["POST"]
      },
      "action": {
        "type": "rate_limit",
        "requests_per_second": 1000,
        "burst": 1500,
        "key": "api_key",
        "exceeded_response": 429
      },
      "bypass": {
        "header": "X-Meridian-Priority",
        "value": "critical"
      }
    },
    {
      "name": "jwt-enforcement-v12",
      "description": "Validate JWT bearer tokens on all authenticated endpoints",
      "enabled": true,
      "mode": "enforcing",
      "priority": 95,
      "created_at": "2025-11-03T10:00:00Z",
      "last_modified": "2026-02-18T16:44:00Z",
      "owner": "identity-platform",
      "conditions": {
        "path_match": ["/v1/*"],
        "path_exclude": ["/v1/health", "/v1/models/list"],
        "method": ["POST", "PUT", "DELETE"]
      },
      "action": {
        "type": "jwt_validate",
        "issuer": "https://auth.meridian-labs.ai",
        "audience": "inference-api",
        "jwks_uri": "https://auth.meridian-labs.ai/.well-known/jwks.json",
        "clock_skew_seconds": 30
      }
    },
    {
      "name": "bot-detection-v3",
      "description": "Challenge suspicious automated traffic patterns",
      "enabled": true,
      "mode": "enforcing",
      "priority": 90,
      "created_at": "2026-02-14T08:20:00Z",
      "last_modified": "2026-03-28T11:30:00Z",
      "owner": "security-engineering",
      "conditions": {
        "path_match": ["/v1/*"],
        "user_agent_regex": "^(curl|wget|python-requests)/"
      },
      "action": {
        "type": "challenge",
        "challenge_type": "managed",
        "timeout_seconds": 300
      },
      "bypass": {
        "header": "X-Meridian-SDK-Version",
        "pattern": "^meridian-sdk-.*"
      }
    },
    {
      "name": "geo-restrict-v42",
      "description": "Block inference requests from sanctioned regions",
      "enabled": true,
      "mode": "blocking",
      "promoted_from_dry_run": "2026-04-15T03:11:47Z",
      "priority": 85,
      "created_at": "2026-04-11T14:02:08Z",
      "last_modified": "2026-04-15T03:11:47Z",
      "owner": "edge-platform",
      "conditions": {
        "geo_match": {
          "regions": ["sanctioned-list-v7"],
          "classification_mode": "strict",
          "include_cloud_provider_ips": true,
          "cloud_provider_region_mapping": "resolve_to_physical"
        }
      },
      "action": {
        "type": "block",
        "response_code": 403,
        "response_body": "Access denied: request blocked by edge rule geo-restrict-v42"
      },
      "observation": {
        "dry_run_start": "2026-04-11T14:02:08Z",
        "dry_run_end": "2026-04-15T03:11:47Z",
        "dry_run_requests_evaluated": 48291004,
        "dry_run_would_have_blocked": 312,
        "dry_run_false_positive_rate": 0.0
      }
    },
    {
      "name": "payload-size-limit-v2",
      "description": "Reject oversized inference payloads",
      "enabled": true,
      "mode": "enforcing",
      "priority": 80,
      "created_at": "2025-09-15T13:00:00Z",
      "last_modified": "2026-01-07T10:22:00Z",
      "owner": "platform-engineering",
      "conditions": {
        "path_match": ["/v1/inference/*", "/v1/embeddings/*"],
        "method": ["POST"]
      },
      "action": {
        "type": "size_limit",
        "max_body_bytes": 10485760,
        "response_code": 413
      }
    },
    {
      "name": "ip-reputation-v6",
      "description": "Score and optionally block traffic from known-bad IP ranges",
      "enabled": true,
      "mode": "logging",
      "priority": 75,
      "created_at": "2026-03-01T09:00:00Z",
      "last_modified": "2026-04-02T14:18:00Z",
      "owner": "security-engineering",
      "conditions": {
        "ip_reputation_score_below": 30,
        "reputation_provider": "stratos-threat-intel"
      },
      "action": {
        "type": "block",
        "response_code": 403
      }
    },
    {
      "name": "maintenance-window-v1",
      "description": "Return 503 during scheduled maintenance windows",
      "enabled": false,
      "mode": "enforcing",
      "priority": 200,
      "created_at": "2025-08-20T11:00:00Z",
      "last_modified": "2026-04-01T08:00:00Z",
      "owner": "platform-engineering",
      "conditions": {
        "path_match": ["/*"],
        "schedule": {
          "cron": "0 6 * * 0",
          "duration_minutes": 120,
          "timezone": "UTC"
        }
      },
      "action": {
        "type": "static_response",
        "response_code": 503,
        "response_body": "Scheduled maintenance in progress. Please retry later.",
        "retry_after_seconds": 3600
      }
    }
  ]
}
