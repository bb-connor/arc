{
  "manifest_id": "chio.web3-deployment.base-sepolia.template.v1",
  "network_name": "Base Sepolia",
  "chain_id": "eip155:84532",
  "role": "public-testnet-primary",
  "deployment_mode": "deterministic-template",
  "deployer_strategy": "create2",
  "salt_namespace": "chio.web3.v0.1.0",
  "settlement_token": {
    "symbol": "USDC",
    "address": "0x036CbD53842c5426634e7929541eC2318f3dCF7e"
  },
  "oracle_configuration": {
    "note": "Base Sepolia is the public testnet rehearsal lane. Fill the exact feed addresses and reverify heartbeat_seconds against current Chainlink Base Sepolia inventory before approving promotion.",
    "sequencer_uptime_feed": "<base_sepolia_sequencer_uptime_feed>",
    "feeds": [
      {
        "pair": "ETH/USD",
        "address": "<base_sepolia_eth_usd_feed>",
        "heartbeat_seconds": 300
      },
      {
        "pair": "BTC/USD",
        "address": "<base_sepolia_btc_usd_feed>",
        "heartbeat_seconds": 180
      },
      {
        "pair": "USDC/USD",
        "address": "<base_sepolia_usdc_usd_feed>",
        "heartbeat_seconds": 68400
      },
      {
        "pair": "LINK/USD",
        "address": "<base_sepolia_link_usd_feed>",
        "heartbeat_seconds": 86400
      }
    ]
  },
  "contracts": [
    {
      "contract_id": "chio.identity-registry",
      "artifact": "contracts/artifacts/ChioIdentityRegistry.json",
      "source": "contracts/src/ChioIdentityRegistry.sol",
      "constructor_args": [
        "<registry_admin_address>"
      ],
      "create2_salt": "chio.identity-registry.base.v0.1.0"
    },
    {
      "contract_id": "chio.root-registry",
      "artifact": "contracts/artifacts/ChioRootRegistry.json",
      "source": "contracts/src/ChioRootRegistry.sol",
      "constructor_args": [
        "<identity_registry_address>"
      ],
      "create2_salt": "chio.root-registry.base.v0.1.0"
    },
    {
      "contract_id": "chio.escrow",
      "artifact": "contracts/artifacts/ChioEscrow.json",
      "source": "contracts/src/ChioEscrow.sol",
      "constructor_args": [
        "<root_registry_address>",
        "<identity_registry_address>"
      ],
      "create2_salt": "chio.escrow.base.v0.1.0"
    },
    {
      "contract_id": "chio.bond-vault",
      "artifact": "contracts/artifacts/ChioBondVault.json",
      "source": "contracts/src/ChioBondVault.sol",
      "constructor_args": [
        "<root_registry_address>",
        "<identity_registry_address>"
      ],
      "create2_salt": "chio.bond-vault.base.v0.1.0"
    },
    {
      "contract_id": "chio.price-resolver",
      "artifact": "contracts/artifacts/ChioPriceResolver.json",
      "source": "contracts/src/ChioPriceResolver.sol",
      "constructor_args": [
        "<price_admin_address>",
        "<base_sepolia_sequencer_uptime_feed>"
      ],
      "create2_salt": "chio.price-resolver.base.v0.1.0"
    }
  ]
}
