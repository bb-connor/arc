{
  "manifest_id": "arc.web3-deployment.arbitrum-one.template.v1",
  "network_name": "Arbitrum One",
  "chain_id": "eip155:42161",
  "role": "secondary",
  "deployment_mode": "deterministic-template",
  "deployer_strategy": "create2",
  "salt_namespace": "arc.web3.v0.1.0",
  "settlement_token": {
    "symbol": "USDC",
    "address": "0xaf88d065e77c8cC2239327C5EDb3A432268e5831"
  },
  "oracle_configuration": {
    "note": "Arbitrum remains the bounded secondary chain. The contract set and CREATE2 salts stay identical; only price-resolver feed inventory changes per chain.",
    "feeds": [
      {
        "pair": "ETH/USD",
        "address": "0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612"
      },
      {
        "pair": "USDC/USD",
        "address": "0x50834F3163758fcC1Df9973b6e91f0F0F0434aD3"
      },
      {
        "pair": "BTC/USD",
        "address": "0x6ce185860a4963106506C203335A2910413708e9"
      }
    ]
  },
  "contracts": [
    {
      "contract_id": "arc.identity-registry",
      "artifact": "contracts/artifacts/ArcIdentityRegistry.json",
      "source": "contracts/src/ArcIdentityRegistry.sol",
      "constructor_args": [
        "<registry_admin_address>"
      ],
      "create2_salt": "arc.identity-registry.base.v0.1.0"
    },
    {
      "contract_id": "arc.root-registry",
      "artifact": "contracts/artifacts/ArcRootRegistry.json",
      "source": "contracts/src/ArcRootRegistry.sol",
      "constructor_args": [
        "<identity_registry_address>"
      ],
      "create2_salt": "arc.root-registry.base.v0.1.0"
    },
    {
      "contract_id": "arc.escrow",
      "artifact": "contracts/artifacts/ArcEscrow.json",
      "source": "contracts/src/ArcEscrow.sol",
      "constructor_args": [
        "<root_registry_address>",
        "<identity_registry_address>"
      ],
      "create2_salt": "arc.escrow.base.v0.1.0"
    },
    {
      "contract_id": "arc.bond-vault",
      "artifact": "contracts/artifacts/ArcBondVault.json",
      "source": "contracts/src/ArcBondVault.sol",
      "constructor_args": [
        "<root_registry_address>",
        "<identity_registry_address>"
      ],
      "create2_salt": "arc.bond-vault.base.v0.1.0"
    },
    {
      "contract_id": "arc.price-resolver",
      "artifact": "contracts/artifacts/ArcPriceResolver.json",
      "source": "contracts/src/ArcPriceResolver.sol",
      "constructor_args": [
        "<price_admin_address>",
        "<arbitrum_sequencer_uptime_feed>"
      ],
      "create2_salt": "arc.price-resolver.base.v0.1.0"
    }
  ]
}
