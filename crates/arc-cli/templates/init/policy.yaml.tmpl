# ARC starter policy for {{PROJECT_NAME}}

kernel:
  max_capability_ttl: 600
  delegation_depth_limit: 3

guards:
  forbidden_path:
    enabled: true
  shell_command:
    enabled: true

capabilities:
  default:
    tools:
      - server: "hello"
        tool: "hello_world"
        operations: [invoke]
        ttl: 300
