{
  "schema": "arc.web3-contract-package.v1",
  "package_id": "arc.official-web3-contracts",
  "version": "0.1.0",
  "arc_contract_version": "2.0",
  "contracts": [
    {
      "contract_id": "arc.root-registry",
      "kind": "root_registry",
      "interface_name": "IArcRootRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IArcRootRegistry.json",
      "implementation_reference": "contracts/src/ArcRootRegistry.sol",
      "immutable": true
    },
    {
      "contract_id": "arc.escrow",
      "kind": "escrow",
      "interface_name": "IArcEscrow",
      "abi_reference": "contracts/artifacts/interfaces/IArcEscrow.json",
      "implementation_reference": "contracts/src/ArcEscrow.sol",
      "immutable": true
    },
    {
      "contract_id": "arc.bond-vault",
      "kind": "bond_vault",
      "interface_name": "IArcBondVault",
      "abi_reference": "contracts/artifacts/interfaces/IArcBondVault.json",
      "implementation_reference": "contracts/src/ArcBondVault.sol",
      "immutable": true
    },
    {
      "contract_id": "arc.identity-registry",
      "kind": "identity_registry",
      "interface_name": "IArcIdentityRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IArcIdentityRegistry.json",
      "implementation_reference": "contracts/src/ArcIdentityRegistry.sol",
      "immutable": false
    },
    {
      "contract_id": "arc.price-resolver",
      "kind": "price_resolver",
      "interface_name": "IArcPriceResolver",
      "abi_reference": "contracts/artifacts/interfaces/IArcPriceResolver.json",
      "implementation_reference": "contracts/src/ArcPriceResolver.sol",
      "immutable": true
    }
  ],
  "bindings": [
    {
      "language": "rust",
      "crate_path": "crates/arc-web3-bindings/src/lib.rs",
      "module_name": "arc_web3_bindings",
      "contract_ids": [
        "arc.root-registry",
        "arc.escrow",
        "arc.bond-vault",
        "arc.identity-registry",
        "arc.price-resolver"
      ]
    }
  ],
  "deferred_capabilities": [
    "cross-chain-ccip",
    "permissionless-operator-discovery",
    "unattended-mainnet-rollout"
  ]
}
