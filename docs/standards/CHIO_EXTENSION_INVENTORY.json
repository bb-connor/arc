  "canonical_truth": [
    {
      "id": "arc.canonical.capability",
      "name": "Capability and approval artifacts",
      "crate_path": "crates/chio-core/src/capability.rs",
      "contract_kind": "capability",
      "artifact_schemas": [
        "capability_token",
        "governed_approval_token"
      ],
      "notes": "Extensions may supply evidence or execution behind named seams, but they must not redefine scope attenuation, approval binding, or delegation semantics.",
      "extensions_may_write": false
    },
    {
      "id": "arc.canonical.receipt",
      "name": "Signed receipts and checkpoints",
      "crate_path": "crates/chio-core/src/receipt.rs",
      "contract_kind": "receipt",
      "artifact_schemas": [
        "chio.receipt.v1",
        "chio.checkpoint.v1"
      ],
      "notes": "Receipt, child-receipt, and checkpoint truth stays canonical even when extensions provide storage, projection, or downstream transport.",
      "extensions_may_write": false
    },
    {
      "id": "arc.canonical.policy",
      "name": "Local policy activation and trust decisions",
      "crate_path": "crates/chio-policy/src/evaluate.rs",
      "contract_kind": "policy",
      "artifact_schemas": [
        "arc.policy.runtime.v1",
        "chio.generic-trust-activation.v1"
      ],
      "notes": "Custom adapters may surface external evidence, but local policy activation and trust admission remain Chio-owned decisions.",
      "extensions_may_write": false
    },
    {
      "id": "arc.canonical.artifacts",
      "name": "Signed Chio artifact families",
      "crate_path": "crates/chio-core/src/lib.rs",
      "contract_kind": "artifact_family",
      "artifact_schemas": [
        "chio.manifest.v1",
        "chio.agent-passport.v1",
        "arc.runtime-attestation.appraisal-result.v1"
      ],
      "notes": "Extensions may project, import, or dispatch around these artifacts only through named envelopes that preserve schema and signing truth.",
      "extensions_may_write": false
    }
  ],
