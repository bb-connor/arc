{
  "schema": "chio.web3-contract-package.v1",
  "package_id": "chio.official-web3-contracts",
  "version": "0.1.0",
  "chio_contract_version": "2.0",
  "contracts": [
    {
      "contract_id": "chio.root-registry",
      "kind": "root_registry",
      "interface_name": "IArcRootRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IArcRootRegistry.json",
      "implementation_reference": "contracts/src/ChioRootRegistry.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.escrow",
      "kind": "escrow",
      "interface_name": "IArcEscrow",
      "abi_reference": "contracts/artifacts/interfaces/IArcEscrow.json",
      "implementation_reference": "contracts/src/ChioEscrow.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.bond-vault",
      "kind": "bond_vault",
      "interface_name": "IArcBondVault",
      "abi_reference": "contracts/artifacts/interfaces/IArcBondVault.json",
      "implementation_reference": "contracts/src/ChioBondVault.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.identity-registry",
      "kind": "identity_registry",
      "interface_name": "IArcIdentityRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IArcIdentityRegistry.json",
      "implementation_reference": "contracts/src/ChioIdentityRegistry.sol",
      "immutable": false
    },
    {
      "contract_id": "chio.price-resolver",
      "kind": "price_resolver",
      "interface_name": "IArcPriceResolver",
      "abi_reference": "contracts/artifacts/interfaces/IArcPriceResolver.json",
      "implementation_reference": "contracts/src/ChioPriceResolver.sol",
      "immutable": true
    }
  ],
  "bindings": [
    {
      "language": "rust",
      "crate_path": "crates/chio-web3-bindings/src/lib.rs",
      "module_name": "chio_web3_bindings",
      "contract_ids": [
        "chio.root-registry",
        "chio.escrow",
        "chio.bond-vault",
        "chio.identity-registry",
        "chio.price-resolver"
      ]
    }
  ],
  "deferred_capabilities": [
    "cross-chain-ccip",
    "permissionless-operator-discovery",
    "unattended-mainnet-rollout"
  ]
}
