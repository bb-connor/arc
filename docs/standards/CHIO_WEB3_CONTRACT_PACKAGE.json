{
  "schema": "chio.web3-contract-package.v1",
  "package_id": "chio.official-web3-contracts",
  "version": "0.1.0",
  "chio_contract_version": "2.0",
  "contracts": [
    {
      "contract_id": "chio.root-registry",
      "kind": "root_registry",
      "interface_name": "IChioRootRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IChioRootRegistry.json",
      "implementation_reference": "contracts/src/ChioRootRegistry.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.escrow",
      "kind": "escrow",
      "interface_name": "IChioEscrow",
      "abi_reference": "contracts/artifacts/interfaces/IChioEscrow.json",
      "implementation_reference": "contracts/src/ChioEscrow.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.bond-vault",
      "kind": "bond_vault",
      "interface_name": "IChioBondVault",
      "abi_reference": "contracts/artifacts/interfaces/IChioBondVault.json",
      "implementation_reference": "contracts/src/ChioBondVault.sol",
      "immutable": true
    },
    {
      "contract_id": "chio.identity-registry",
      "kind": "identity_registry",
      "interface_name": "IChioIdentityRegistry",
      "abi_reference": "contracts/artifacts/interfaces/IChioIdentityRegistry.json",
      "implementation_reference": "contracts/src/ChioIdentityRegistry.sol",
      "immutable": false
    },
    {
      "contract_id": "chio.price-resolver",
      "kind": "price_resolver",
      "interface_name": "IChioPriceResolver",
      "abi_reference": "contracts/artifacts/interfaces/IChioPriceResolver.json",
      "implementation_reference": "contracts/src/ChioPriceResolver.sol",
      "immutable": true
    }
  ],
  "bindings": [
    {
      "language": "rust",
      "crate_path": "crates/chio-web3-bindings/src/lib.rs",
      "module_name": "chio_web3_bindings",
      "contract_ids": [
        "chio.root-registry",
        "chio.escrow",
        "chio.bond-vault",
        "chio.identity-registry",
        "chio.price-resolver"
      ]
    }
  ],
  "deferred_capabilities": [
    "cross-chain-ccip",
    "permissionless-operator-discovery",
    "unattended-mainnet-rollout"
  ]
}
