{
  "name": "@chio-protocol/sdk",
  "version": "1.0.0",
  "type": "module",
  "description": "TypeScript SDK for the Chio (Chio) protocol",
  "keywords": ["chio", "mcp", "receipts", "capabilities", "agent-governance"],
  "homepage": "https://github.com/bb-connor/chio/tree/main/packages/sdk/chio-ts",
  "bugs": {
    "url": "https://github.com/bb-connor/chio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bb-connor/chio.git",
    "directory": "packages/sdk/chio-ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./invariants": {
      "types": "./dist/invariants/index.d.ts",
      "import": "./dist/invariants/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && node ./scripts/fix-dist-imports.mjs",
    "prepack": "npm run build",
    "test": "node --experimental-strip-types --test ./test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.7.0"
  }
}
