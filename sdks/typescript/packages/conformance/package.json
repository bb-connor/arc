{
  "name": "@chio-protocol/conformance",
  "version": "1.0.0",
  "type": "module",
  "description": "Conformance tests for Chio TypeScript SDK against Rust kernel",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@chio-protocol/node-http": "file:../node-http",
    "@chio-protocol/express": "file:../express",
    "@chio-protocol/fastify": "file:../fastify"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "express": "^5.1.0",
    "fastify": "^5.3.3",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
